{
  "project": {
    "target": ".",
    "type": "auto",
    "ignorePaths": [
      "docs/showcase"
    ]
  },
  "mode": {
    "name": "acceptance",
    "maxFiles": 1000
  },
  "llm": {
    "apiKeyEnv": "AGENT_TEST_LLM_API_KEY",
    "fallbackApiKeyEnv": "OPENAI_API_KEY",
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-5-mini",
    "estimatedInputTokens": 30000,
    "estimatedOutputTokens": 6000,
    "inputUsdPer1M": 0,
    "outputUsdPer1M": 0,
    "maxCostUsd": 5
  },
  "profiles": ["auto"],
  "report": {
    "output": "reports/self/latest",
    "formats": ["md", "json"]
  }
}
