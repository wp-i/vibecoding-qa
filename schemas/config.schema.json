{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-test.local/schemas/config.schema.json",
  "title": "agent-test configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "description": "Local path or GitHub repository URL to scan."
        },
        "type": {
          "type": "string",
          "default": "auto"
        },
        "ignorePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "mode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "const": "acceptance",
          "default": "acceptance"
        },
        "maxFiles": {
          "type": "integer",
          "minimum": 1,
          "default": 1000
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiKeyEnv": {
          "type": "string",
          "default": "AGENT_TEST_LLM_API_KEY"
        },
        "fallbackApiKeyEnv": {
          "type": "string",
          "default": "OPENAI_API_KEY"
        },
        "baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1"
        },
        "model": {
          "type": "string",
          "default": "gpt-5-mini"
        },
        "estimatedInputTokens": {
          "type": "integer",
          "minimum": 1,
          "default": 30000
        },
        "estimatedOutputTokens": {
          "type": "integer",
          "minimum": 1,
          "default": 6000
        },
        "inputUsdPer1M": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "outputUsdPer1M": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "maxCostUsd": {
          "type": "number",
          "minimum": 0,
          "default": 5
        }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["auto"]
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "output": {
          "type": "string",
          "default": "reports/latest"
        },
        "formats": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["md", "pdf", "json"]
          },
          "default": ["md", "pdf", "json"]
        }
      }
    }
  }
}
